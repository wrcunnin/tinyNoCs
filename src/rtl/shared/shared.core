CAPI=2:
name: tinynocs:src:rtl-shared:0.0.1
description: Shared RTL modules for NoC components

filesets:
  fifo_basic:
    files:
      - fifo/fifo_basic.sv
    file_type: systemVerilogSource

  fifo_router:
    files:
      - fifo/fifo_router.sv
    file_type: systemVerilogSource

targets:
  default: &default
    filesets:
      - fifo_basic
      - fifo_router
